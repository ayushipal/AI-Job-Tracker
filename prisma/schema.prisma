generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  jobs     Job[]
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String?
  url         String?
  status      String
  createdAt   DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}